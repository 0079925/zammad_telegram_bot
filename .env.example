# ==============================================================
#  .env.example — скопируйте в .env и заполните реальные значения
#  Никогда не коммитьте .env в репозиторий.
# ==============================================================

# ── Telegram ───────────────────────────────────────────────────────────────────
# Получите у @BotFather: /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Если хотите webhook-режим вместо polling — раскомментируйте:
# TELEGRAM_WEBHOOK_URL=https://bot.example.com/webhook/telegram
# TELEGRAM_WEBHOOK_SECRET=changeme_min32chars

# ── Zammad ─────────────────────────────────────────────────────────────────────
# URL вашего Zammad без trailing slash
ZAMMAD_URL=https://support.example.com

# API-токен сервисного аккаунта (Settings → API → Token Access)
# Права: Tickets: create/read/update, Articles: create/read, Users: create/read/update
ZAMMAD_HTTP_TOKEN=your_zammad_api_token_here

# Секрет для верификации входящих webhook от Zammad (придумайте сами)
ZAMMAD_WEBHOOK_SECRET=changeme_webhook_secret_here

# ID сервисного пользователя Zammad (GET /api/v1/users/me → поле id)
ZAMMAD_INTEGRATION_USER_ID=5

# Названия групп в Zammad (точное совпадение, включая регистр)
ZAMMAD_GROUP_SUPPORT=Support L1
ZAMMAD_GROUP_MANAGER=manager

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=botuser
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=zammadbot

# Строка подключения (подставляется автоматически в docker-compose)
# DATABASE_URL=postgresql+asyncpg://botuser:change_me@postgres:5432/zammadbot
# Для локального MVP без PostgreSQL можно использовать:
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
# REDIS_URL=redis://:password@redis:6379/0

# ── Приложение ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8080
BOT_PORT=8080                    # внешний порт (для docker-compose)
ZAMMAD_WEBHOOK_PATH=/webhook/zammad

# ── Лимиты вложений ────────────────────────────────────────────────────────────
MAX_ATTACHMENT_SIZE_BYTES=20971520   # 20 МБ

# ── Тайм-ауты и повторные попытки ──────────────────────────────────────────────
ZAMMAD_REQUEST_TIMEOUT=30.0
ZAMMAD_MAX_RETRIES=3
ZAMMAD_RETRY_WAIT_SECONDS=1.0
