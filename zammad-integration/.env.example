# =============================================================
#  Zammad Integration — Environment Variables
#  Copy to .env and fill in real values
# =============================================================

# ── Zammad ────────────────────────────────────────────────────
ZAMMAD_URL=https://zammad.example.com
# Preferred: HTTP Token auth (Admin > Profile > Token Access)
ZAMMAD_ADMIN_TOKEN=TODO_your_zammad_api_token
# Alternative: basic auth (used only if TOKEN is empty)
ZAMMAD_ADMIN_USER=admin@example.com
ZAMMAD_ADMIN_PASS=TODO_password

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=TODO_your_bot_token
# Full public URL where Telegram delivers webhooks (must be HTTPS)
# Example: https://yourdomain.com/webhook/telegram
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhook/telegram

# Chat ID of the manager/supervisor who receives SLA alerts
MANAGER_TELEGRAM_CHAT_ID=TODO_manager_chat_id

# ── VIP routing mode ─────────────────────────────────────────
# A = separate "VIP L1" group (needs extra agents)
# B = same Support L1, priority=high + SLA VIP (recommended)
VIP_ROUTING_MODE=B

# ── SLA times (minutes) ──────────────────────────────────────
# Standard SLA
SLA_STANDARD_P1_FIRST_RESPONSE=60
SLA_STANDARD_P2_FIRST_RESPONSE=240
SLA_STANDARD_P1_SOLUTION=480
SLA_STANDARD_P2_SOLUTION=1440

# VIP SLA
SLA_VIP_P1_FIRST_RESPONSE=15
SLA_VIP_P2_FIRST_RESPONSE=60
SLA_VIP_P1_SOLUTION=120
SLA_VIP_P2_SOLUTION=480

# Alert on P2 SLA breach? (true/false)
SLA_ALERT_P2=true

# ── Calendar / Timezone ──────────────────────────────────────
# Server timezone for business hours calendar
# Use TZ identifier: Europe/Moscow, UTC, etc.
BUSINESS_HOURS_TIMEZONE=Europe/Moscow
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00

# ── SMTP (for SLA breach emails) ─────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=TODO_smtp_password
SMTP_FROM=Support <noreply@example.com>
SMTP_TLS=true

# ── Database (telegram-gateway) ──────────────────────────────
# SQLite path inside the container (volume-mounted)
DATABASE_URL=sqlite:////data/gateway.db

# ── Gateway security ─────────────────────────────────────────
# Shared secret for Zammad → gateway webhooks
ZAMMAD_WEBHOOK_SECRET=TODO_random_secret_32chars

# ── Service ports ────────────────────────────────────────────
GATEWAY_PORT=8080
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
